# ── Backend Environment Variables ──
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

API_KEY=your-nvidia-api-key-here
DB_PASSWORD=your-database-password-here
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=your-64-char-hex-secret-here

# PayPal Subscription Configuration
# Get sandbox credentials from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_SECRET=your-paypal-sandbox-secret

# Dodo Payments Configuration
# Get credentials from https://app.dodopayments.com → Developer → API Keys
DODO_API_KEY=your-dodo-api-key-here
DODO_WEBHOOK_SECRET=your-dodo-webhook-secret-here
DODO_BASE_URL=https://test.dodopayments.com
DODO_STANDARD_PRODUCT_ID=your-standard-product-id
DODO_PREMIUM_PRODUCT_ID=your-premium-product-id

# Email (Gmail SMTP — required for password reset emails)
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Production overrides (optional)
# APP_CORS_ORIGINS=https://yourdomain.com
