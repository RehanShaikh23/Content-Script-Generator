# ── Backend Environment Variables ──
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

API_KEY=your-nvidia-api-key-here
DB_PASSWORD=your-database-password-here
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=your-64-char-hex-secret-here

# PayPal Subscription Configuration
# Get sandbox credentials from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_SECRET=your-paypal-sandbox-secret

# Production overrides (optional)
# APP_CORS_ORIGINS=https://yourdomain.com

